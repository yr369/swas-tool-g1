+    SQL, so this has a low hit rate in general - but a genuine hit is
+    typically high-value (auth bypass on XML-backed user stores).
+    """
+    parsed = httpx.URL(url)
+    if not parsed.query:
+        return None
+    existing_params = dict(parsed.params)
+
+    try:
