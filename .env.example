# Copy this file to ".env" and fill in real values.
# NEVER commit the actual ".env" file to git - it's already in .gitignore.

# --- Basic auth (REQUIRED - protects the whole app) ---
# Without this, anyone who finds your server's IP can browse projects/
# findings and trigger scans against arbitrary targets, unauthenticated.
# Caddy gates the entire site (UI + API + WebSocket) with these.
#
# To set this up on your OCI server, AFTER `docker compose up -d` once
# (so the caddy image exists locally):
#   docker compose exec caddy caddy hash-password --plaintext 'yourpassword'
# That prints a bcrypt hash - paste it as SWAS_AUTH_HASH below, and pick
# any username for SWAS_AUTH_USER. Then `docker compose restart caddy`.
# Leaving these blank will make Caddy refuse to start - that's
# intentional, not a bug (a blank hash means "no real password").
SWAS_AUTH_USER=
SWAS_AUTH_HASH=

# --- PostgreSQL ---
POSTGRES_USER=swas_user
POSTGRES_PASSWORD=changeme_use_a_real_password
POSTGRES_DB=swas_db

# --- Gemini API (Google AI Studio) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Tier-2 AI fallback (optional) ---
# Once every model in Gemini's free-tier rotation is exhausted for the
# day, triage.py and scope_parser.py fall through to these instead of
# just failing for the rest of the day. Both are opt-in - leave blank
# to skip that provider (leave both blank to keep the old Gemini-only
# behavior exactly as-is).
#
# Model slugs default to the OpenRouter catalog naming
# ("org/model"), and both point at OpenRouter's endpoint by default
# since one OpenRouter key can cover both providers. If you're calling
# DeepSeek or Zhipu (GLM) directly instead, override the *_BASE_URL and
# *_MODEL vars to match that provider's own API and model name.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-ai/deepseek-v4-flash
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1

GLM_API_KEY=
GLM_MODEL=z-ai/glm-5.2
GLM_BASE_URL=https://openrouter.ai/api/v1

LLAMA_API_KEY=
LLAMA_MODEL=meta/llama-3.3-70b-instruct
LLAMA_BASE_URL=https://openrouter.ai/api/v1

# --- Notifications (optional) ---
# If set, scan-complete notifications are sent here via the "notify" tool.
# Leave unset/blank to skip notifications entirely (the default for now).
NOTIFY_WEBHOOK_URL=

# --- Researcher identification header (recommended for real programs) ---
# Many bug bounty programs require an identifying header on all traffic
# so their security team can tell authorized researcher activity apart
# from real attacks, and so your scans aren't blocked as malicious.
# Example for Bugcrowd: RESEARCH_HEADER_NAME=X-Bug-Bounty
#                        RESEARCH_HEADER_VALUE=your_bugcrowd_username
# Leave both blank to send no extra header (fine for authorized test
# targets like scanme.nmap.org that don't require one).
RESEARCH_HEADER_NAME=
RESEARCH_HEADER_VALUE=

# --- Hard scope denylist (defense-in-depth) ---
# Comma-separated domain fragments that must NEVER be scanned, even if
# accidentally marked in-scope. Some programs explicitly exclude specific
# domains despite them looking related to the main target. Example:
# DENYLIST_DOMAINS=leadfamly.com,playable.com
DENYLIST_DOMAINS=

# --- Nuclei excluded tags (optional, per-deploy toggle) ---
# Comma-separated nuclei tags excluded from every scan. Defaults to
# "ssl,tls" if unset, since mature programs consistently close these as
# Informational/N-A - excluding them saves scan time and keeps the
# review queue focused on higher-value findings (SSRF, exposed admin
# panels, unauthenticated APIs, etc). Set to an empty string to disable
# and scan everything, or override with a different tag list for a
# specific program.
NUCLEI_EXCLUDE_TAGS=ssl,tls

# --- Nuclei minimum severity (optional, per-deploy toggle) ---
# Comma-separated severities nuclei is allowed to report. Defaults to
# everything except "info" - real scan data showed ~92% of nuclei
# output was info-tier recon noise (DNS fingerprinting, tech-detect,
# header/cookie presence checks) that's essentially never reportable.
# This is applied via nuclei's own -severity flag, so excluded
# severities aren't just filtered after the fact - nuclei spends less
# time per scan too. Set to an empty string to disable and see
# everything again (e.g. while debugging why a specific template isn't
# firing).
NUCLEI_MIN_SEVERITY=low,medium,high,critical,unknown

# --- Recon cache (optional, per-deploy toggle) ---
# Hours a target's subfinder result stays reusable before recon runs it
# for real again. Subdomain sets rarely change hour to hour, so this
# saves real time on frequent schedules (6-hourly) and repeated manual
# rescans without going stale for daily/weekly schedules, whose interval
# already exceeds the default window. Set to 0 to disable and always run
# fresh subfinder.
RECON_CACHE_HOURS=12

# --- FP filter strict mode (optional, per-deploy toggle) ---
# SSL/TLS/cert findings and missing-security-header noise (CSP, HSTS,
# weak ciphers, self-signed/expired certs) are now filtered by default,
# always - no toggle needed, since mature programs consistently close
# these as Informational/N-A. This toggle now covers the remaining,
# more program-specific exclusions: open redirects and subdomain
# takeover without proof of exploitation, and DNS SPF/DMARC gaps. Check
# YOUR program's brief before enabling - some programs DO want these
# findings. Default: off (false).
FP_FILTER_STRICT_MODE=false

# --- App settings ---
# Comma-separated list of allowed origins for the frontend to call the API from.
# For local/single-server deploys, this can just be your server's domain or IP.
ALLOWED_ORIGINS=http://localhost,http://localhost:5173
